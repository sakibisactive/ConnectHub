{
  "name": "connecthub",
  "version": "1.0.0",
  "description": "ConnectHub - Real-Time Messaging Application built with MERN Stack, Socket.IO, and Redis",
  "main": "server/server.js",
  "scripts": {
    "start": "node server/server.js",
    "server": "nodemon server/server.js",
    "client": "npm run dev --prefix client",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "seed": "node server/seed/seed.js",
    "build": "npm run build --prefix client",
    "test": "echo \"Error: no test specified\" && exit 0"
  },
  "keywords": [
    "mern",
    "socket.io",
    "react",
    "express",
    "mongodb",
    "redis",
    "realtime-chat"
  ],
  "author": "ConnectHub Team",
  "license": "ISC",
  "devDependencies": {
    "concurrently": "^8.2.2",
    "nodemon": "^3.1.0"
  }
}
